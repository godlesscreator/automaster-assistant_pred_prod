# ============================================================
# AutoMaster+ Assistant — Конфигурация окружения
# ============================================================
# Скопируйте этот файл в .env и заполните свои значения:
#   cp .env.example .env
# ============================================================

# ============================================================
# 🔴 КРИТИЧЕСКИЕ НАСТРОЙКИ (обязательны для продакшна)
# ============================================================

# Секретный ключ Flask — ОБЯЗАТЕЛЕН! Сгенерируйте уникальный:
#   python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Пароль для входа в админ-панель — ОБЯЗАТЕЛЕН!
ADMIN_PASSWORD=

# ============================================================
# 🟡 ВАЖНЫЕ НАСТРОЙКИ (рекомендуются)
# ============================================================

# Telegram Bot Token от @BotFather
TELEGRAM_BOT_TOKEN=

# OpenAI API Key для AI-консультаций
OPENAI_API_KEY=

# Google Sheets ID для хранения заявок (если PostgreSQL отключён)
GOOGLE_SHEETS_ID=

# ============================================================
# 🟢 ОПЦИОНАЛЬНЫЕ НАСТРОЙКИ
# ============================================================

# --- Flask ---
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
FLASK_DEBUG=false
WEB_ORIGIN=http://localhost:8000
SESSION_LIFETIME_DAYS=7

# --- Telegram ---
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# --- OpenAI ---
OPENAI_MODEL=gpt-4o-mini
OPENAI_ASSISTANT_ID=
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=1024

# --- Google Sheets ---
GOOGLE_API_KEY=
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_SHEETS_RANGE="админ!A1"
GOOGLE_SHEETS_COLUMNS=name,phone,car,service,desired_datetime,comment

# --- PostgreSQL (включите для продакшна) ---
DATABASE_ENABLED=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/automaster
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# --- Redis (для сессий и rate limiting) ---
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# --- Админ-панель ---
ADMIN_USERNAME=admin
ADMIN_ENABLED=true

# --- Sentry (мониторинг ошибок) ---
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Логирование ---
LOG_LEVEL=INFO
LOG_FILE=
LOG_JSON=false

# --- Прочее ---
TZ=Europe/Moscow
TILDA_SITE_URL=
NGROK_AUTHTOKEN=